<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Properties ────────────────────────────────────────── -->
    <property name="APP_NAME" value="macro-balance-backend"/>

    <property name="LOG_DIR"     value="logs"/>
    <property name="MAX_SIZE"    value="10MB"/>
    <property name="MAX_HISTORY" value="30"/>  <!-- days -->

    <!-- ── Patterns ──────────────────────────────────────────── -->
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) %cyan([%thread]) %yellow(%logger{36}) - %msg%n"/>

    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n"/>

    <!-- ── Console Appender ───────────────────────────────────── -->
    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ── General Application Log ───────────────────────────── -->
    <appender name="APP_FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}.log</file>
        <rollingPolicy
                class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Daily rollover, keeps 30 days -->
            <fileNamePattern>
                ${LOG_DIR}/archived/${APP_NAME}-%d{yyyy-MM-dd}.%i.log.gz
            </fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy
                    class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>${MAX_SIZE}</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ── Error-only Log ────────────────────────────────────── -->
    <appender name="ERROR_FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}-error.log</file>
        <!-- Only capture ERROR level -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy
                class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>
                ${LOG_DIR}/archived/${APP_NAME}-error-%d{yyyy-MM-dd}.log.gz
            </fileNamePattern>
            <maxHistory>${MAX_HISTORY}</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ── Payment Log (separate file for audit) ─────────────── -->
    <appender name="PAYMENT_FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}-payments.log</file>
        <rollingPolicy
                class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>
                ${LOG_DIR}/archived/${APP_NAME}-payments-%d{yyyy-MM-dd}.log.gz
            </fileNamePattern>
            <maxHistory>90</maxHistory>  <!-- keep payment logs longer -->
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ── Logger Configurations ─────────────────────────────── -->

    <!-- Your application code — DEBUG in dev, INFO in prod -->
    <springProfile name="default,dev">
        <logger name="com.macrobalance" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="APP_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>
    </springProfile>

    <springProfile name="prod">
        <logger name="com.macrobalance" level="INFO" additivity="false">
            <appender-ref ref="APP_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>
    </springProfile>

    <!-- Payment service gets its own dedicated logger -->
    <logger name="com.macrobalance.payment"
            level="INFO"
            additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="PAYMENT_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- Hibernate SQL — only in dev, too noisy for prod -->
    <springProfile name="default,dev">
        <logger name="org.hibernate.SQL"
                level="DEBUG"
                additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
        <logger name="org.hibernate.type.descriptor.sql"
                level="TRACE"
                additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
    </springProfile>

    <!-- Flyway -->
    <logger name="org.flywaydb" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP_FILE"/>
    </logger>

    <!-- Spring Security — useful during development -->
    <springProfile name="default,dev">
        <logger name="org.springframework.security"
                level="DEBUG"
                additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
    </springProfile>

    <!-- Root — everything else -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

</configuration>